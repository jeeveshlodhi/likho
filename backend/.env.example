# ============================================
# LIKHO BACKEND ENVIRONMENT CONFIGURATION
# ============================================

# Application Settings
PROJECT_NAME=Likho Backend
API_V1_STR=/api/v1

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL (recommended for production)
# Format: postgresql://username:password@host:port/database
# For local development with Docker:
#   docker run --name likho-postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=likho -p 5432:5432 -d postgres:latest
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/likho

# ============================================
# JWT AUTHENTICATION
# ============================================
# IMPORTANT: Change this to a long random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string-at-least-32-characters

# Token expiration in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins (no spaces!)
# Examples:
#   Development: http://localhost:3000,http://localhost:5173
#   Production: https://app.example.com,https://www.example.com
#   Tauri Desktop: tauri://localhost
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:1420,http://127.0.0.1:1420,tauri://localhost

# ============================================
# S3 RELEASES UPLOAD (OPTIONAL)
# ============================================
# Required only if you want "Upload build to S3" in the admin Releases dashboard.
# Leave empty to disable; then use manual S3 upload (e.g. AWS CLI) and paste URL when registering.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_RELEASES_BUCKET=
AWS_REGION=us-east-1
AWS_RELEASES_PREFIX=releases

# ============================================
# NOTES
# ============================================
# 1. Do NOT use spaces around commas in BACKEND_CORS_ORIGINS
# 2. All values should be on a single line (no line breaks)
# 3. Copy this file to .env and update values for your environment
# 4. NEVER commit .env to version control!
